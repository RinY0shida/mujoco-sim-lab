<mujoco model="inverted_pendulum">
  <option gravity="0 0 -9.81" integrator="RK4" timestep="0.1"/>

  <asset>
    <mesh name="stage_mesh" file="../meshes/stage.stl" scale="0.001 0.001 0.001"/>
    <mesh name="pole_mesh" file="../meshes/pole.stl" scale="0.001 0.001 0.001"/>
  </asset>

  <worldbody>
    <body name="stage" pos="0 0 0">
      <geom type="mesh" mesh="stage_mesh" rgba="1 0 0 1"/>
      <site name="muscle_origin_site" pos="0.05 0 0.04"/>
      <site name="muscle_origin_site_1" pos="-0.05 0 0.04"/>
      <body name="pole" pos="0 0 0">
	<joint name="hinge1" type="hinge" pos="0 0 0.03" axis="0 1 0" range="-45 45" limited="true" damping="1.0"/>
	<inertial pos="0 0 0" mass="1.0" diaginertia="0.1 0.1 0.1"/>
	<geom type="mesh" mesh="pole_mesh" rgba="1 0 0 1"/>
	<site name="muscle_insert_site" pos="0 0 0.10"/>
	<site name="muscle_insert_site_1" pos="0 0 0.10"/>
      </body>
    </body>
  </worldbody>

  <tendon>
    <spatial name="muscle_tendon">
      <site site="muscle_origin_site"/>
      <site site="muscle_insert_site"/>
    </spatial>
    <spatial name="muscle_tendon_1">
      <site site="muscle_origin_site_1"/>
      <site site="muscle_insert_site_1"/>
    </spatial>
  </tendon>


  <actuator>
    <motor joint="hinge1" ctrlrange="-45 45" gear="1"/>
    <muscle name = "muscle1" tendon = "muscle_tendon" ctrlrange="0 1"/>
    <muscle name = "muscle2" tendon = "muscle_tendon_1" ctrlrange="0 1"/>
  </actuator>

</mujoco>
